# .env.example

# Required — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
# Callback URL: https://your-domain/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App (https://console.cloud.google.com/apis/credentials)
# Callback URL: https://your-domain/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Authentik OIDC Provider
# Callback URL: https://your-domain/auth/callback/authentik
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_ISSUER=https://your-authentik-instance/application/o/your-app-slug/
